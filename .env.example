# GoPro Plus credentials (get from browser Developer Tools)
# See README.md for instructions
AUTH_TOKEN=your_gp_access_token_here
USER_ID=your_gp_user_id_here

# Optional settings
# ACTION=download
# DOWNLOAD_MODE=zip
# WORKERS=3
# START_PAGE=1
# PAGES=1000000
# PER_PAGE=30
# DOWNLOAD_PATH=./download
# CHUNK_SIZE=65536
# PROGRESS_MODE=noline
# RETRY_COUNT=5
# RETRY_DELAY=5
# VERBOSE=false

# Upload settings (optional — default: local only)
# UPLOAD_PROTOCOL=ftp
# UPLOAD_HOST=192.168.1.100
# UPLOAD_PORT=21
# UPLOAD_USER=user
# UPLOAD_PASS=password
# UPLOAD_PATH=/gopro-backup
# UPLOAD_SHARE=share_name  # SMB only
# UPLOAD_TLS=false          # FTP only
